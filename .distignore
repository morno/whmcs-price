# Files and folders excluded from WordPress.org SVN deploy
# The 10up/action-wordpress-plugin-deploy action reads this file.
# Filename must be .distignore (with leading dot) to be detected.

# Git internals
.git
.gitignore
.gitattributes

# GitHub workflows and assets
.github
.wordpress-org

# Dev-only docs
CHANGELOG.md
README.md
STRUCTURE.md
.distignore

# Node / build tooling
node_modules
package.json
package-lock.json
webpack.config.js

# Block JS/CSS source files (only compiled blocks/build/ is needed by WordPress)
blocks/whmcs-price-product/index.js
blocks/whmcs-price-product/edit.js
blocks/whmcs-price-product/index.css
blocks/whmcs-price-product/styles.css
blocks/whmcs-price-product/package.json
blocks/whmcs-price-domain/index.js
blocks/whmcs-price-domain/edit.js
blocks/whmcs-price-domain/index.css
blocks/whmcs-price-domain/styles.css

# Translations — handled automatically by translate.wordpress.org
languages
